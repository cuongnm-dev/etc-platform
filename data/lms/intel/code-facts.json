{
  "versions": {
    "nextjs": "^14",
    "react": "^18",
    "nestjs": "^10",
    "typeorm": "^0.3",
    "typescript": "^5",
    "tailwindcss": "^3.4.17",
    "stripe": "^22.0.2",
    "ioredis": "^5",
    "pg": "^8",
    "jsonwebtoken": "^9",
    "bcrypt": "^6.0.0",
    "turbo": "latest",
    "lucide-react": "^1.8.0"
  },
  "api_routes": [
    { "method": "POST", "path": "/api/auth/login", "controller": "AuthController" },
    { "method": "POST", "path": "/api/auth/register", "controller": "AuthController" },
    { "method": "POST", "path": "/api/auth/verify-email", "controller": "AuthController" },
    { "method": "POST", "path": "/api/auth/resend-verification", "controller": "AuthController" },
    { "method": "POST", "path": "/api/auth/forgot-password", "controller": "AuthController" },
    { "method": "POST", "path": "/api/auth/reset-password", "controller": "AuthController" },
    { "method": "GET", "path": "/api/auth/me", "controller": "AuthController" },
    { "method": "PATCH", "path": "/api/auth/update-password", "controller": "AuthController" },
    { "method": "GET", "path": "/api/courses", "controller": "CoursesController" },
    { "method": "POST", "path": "/api/courses", "controller": "CoursesController" },
    { "method": "GET", "path": "/api/courses/:id", "controller": "CoursesController" },
    { "method": "PATCH", "path": "/api/courses/:id", "controller": "CoursesController" },
    { "method": "POST", "path": "/api/courses/:id/publish", "controller": "CoursesController" },
    { "method": "POST", "path": "/api/courses/:id/unpublish", "controller": "CoursesController" },
    { "method": "GET", "path": "/api/courses/:id/sections", "controller": "CoursesController" },
    { "method": "GET", "path": "/api/courses/:id/lectures", "controller": "CoursesController" },
    { "method": "GET", "path": "/api/courses/:id/exams", "controller": "CoursesController" },
    { "method": "POST", "path": "/api/courses/:id/exams", "controller": "CoursesController" },
    { "method": "PATCH", "path": "/api/courses/:id/exams/:examId", "controller": "CoursesController" },
    { "method": "DELETE", "path": "/api/courses/:id/exams/:examId", "controller": "CoursesController" },
    { "method": "GET", "path": "/api/courses/:id/exams/:examId/questions", "controller": "CoursesController" },
    { "method": "POST", "path": "/api/courses/:id/exams/:examId/questions", "controller": "CoursesController" },
    { "method": "DELETE", "path": "/api/courses/:id/exams/:examId/questions/:questionId", "controller": "CoursesController" },
    { "method": "GET", "path": "/api/public/courses", "controller": "PublicCoursesController" },
    { "method": "GET", "path": "/api/public/courses/:courseId", "controller": "PublicCoursesController" },
    { "method": "GET", "path": "/api/sections", "controller": "SectionsController" },
    { "method": "POST", "path": "/api/sections", "controller": "SectionsController" },
    { "method": "PATCH", "path": "/api/sections/:id", "controller": "SectionsController" },
    { "method": "DELETE", "path": "/api/sections/:id", "controller": "SectionsController" },
    { "method": "PATCH", "path": "/api/courses/:id/sections/reorder", "controller": "SectionsController" },
    { "method": "POST", "path": "/api/lectures", "controller": "LecturesController" },
    { "method": "PATCH", "path": "/api/lectures/:id", "controller": "LecturesController" },
    { "method": "DELETE", "path": "/api/lectures/:id", "controller": "LecturesController" },
    { "method": "PATCH", "path": "/api/courses/:id/lectures/reorder", "controller": "LecturesController" },
    { "method": "GET", "path": "/api/questions", "controller": "QuestionsController" },
    { "method": "POST", "path": "/api/questions", "controller": "QuestionsController" },
    { "method": "PATCH", "path": "/api/questions/:id", "controller": "QuestionsController" },
    { "method": "DELETE", "path": "/api/questions/:id", "controller": "QuestionsController" },
    { "method": "GET", "path": "/api/payments", "controller": "PaymentsController" },
    { "method": "POST", "path": "/api/payments/create-intent", "controller": "PaymentsController" },
    { "method": "POST", "path": "/api/payments/webhook", "controller": "PaymentsController" },
    { "method": "GET", "path": "/api/student/courses", "controller": "StudentCoursesController" },
    { "method": "GET", "path": "/api/student/courses/:courseId", "controller": "StudentCoursesController" },
    { "method": "GET", "path": "/api/student/courses/:courseId/qa", "controller": "StudentCoursesController" },
    { "method": "POST", "path": "/api/student/courses/:courseId/qa", "controller": "StudentCoursesController" },
    { "method": "POST", "path": "/api/student/courses/:courseId/qa/:questionId/answer", "controller": "StudentCoursesController" },
    { "method": "PATCH", "path": "/api/student/courses/:courseId/lectures/:lectureId/complete", "controller": "StudentCoursesController" },
    { "method": "GET", "path": "/api/exam-schedules", "controller": "ExamScheduleController" },
    { "method": "POST", "path": "/api/exam-schedules", "controller": "ExamScheduleController" },
    { "method": "PATCH", "path": "/api/exam-schedules/:id", "controller": "ExamScheduleController" },
    { "method": "DELETE", "path": "/api/exam-schedules/:id", "controller": "ExamScheduleController" },
    { "method": "GET", "path": "/api/public/exam-schedules", "controller": "PublicExamScheduleController" },
    { "method": "POST", "path": "/api/exam-schedules/:id/ekyc-sessions", "controller": "EkycController" },
    { "method": "GET", "path": "/api/ekyc/ekyc-sessions/:id", "controller": "EkycController" },
    { "method": "PATCH", "path": "/api/ekyc/ekyc-sessions/:id/cccd-front", "controller": "EkycController" },
    { "method": "PATCH", "path": "/api/ekyc/ekyc-sessions/:id/cccd-back", "controller": "EkycController" },
    { "method": "PATCH", "path": "/api/ekyc/ekyc-sessions/:id/face-photo", "controller": "EkycController" },
    { "method": "POST", "path": "/api/ekyc/ekyc-sessions/:id/face-match", "controller": "EkycController" },
    { "method": "GET", "path": "/api/exam-candidates", "controller": "ExamCandidateController" },
    { "method": "POST", "path": "/api/exam-candidates", "controller": "ExamCandidateController" },
    { "method": "POST", "path": "/api/exam-schedules/:id/candidates", "controller": "ExamCandidateController" },
    { "method": "POST", "path": "/api/exam-schedules/:id/postponement", "controller": "ExamCandidateController" },
    { "method": "GET", "path": "/api/exam-sessions/:id", "controller": "ExamSessionController" },
    { "method": "GET", "path": "/api/exam-sessions/:id/state", "controller": "ExamSessionController" },
    { "method": "POST", "path": "/api/exam-sessions/:id/submit", "controller": "ExamSessionController" },
    { "method": "POST", "path": "/api/exam-sessions/:id/violations", "controller": "ExamSessionController" },
    { "method": "PUT", "path": "/api/exam-sessions/:id/answers/:questionId", "controller": "ExamSessionController" },
    { "method": "GET", "path": "/api/certificates/verify/:verifyCode", "controller": "CertificatesController" },
    { "method": "GET", "path": "/api/internal/exam-sessions", "controller": "InternalController" },
    { "method": "GET", "path": "/api/health", "controller": "AppController" }
  ],
  "entities": [
    "UserAccount",
    "Course",
    "Section",
    "Lecture",
    "Exam",
    "ExamQuestion (courses module)",
    "ExamQuestion (examination module)",
    "Question",
    "Payment",
    "CourseEnrollment",
    "LectureCompletion",
    "CourseQaQuestion",
    "CourseQaAnswer",
    "ExamSchedule",
    "ExamCandidate",
    "ExamSession",
    "ExamAnswer",
    "PostponementTicket",
    "EkycSession",
    "PiiAuditLog",
    "Certificate",
    "CertificateOutbox"
  ],
  "services": [
    "web (port 3000) — Next.js 14 frontend",
    "api (port 4000) — NestJS 10 REST API",
    "proctoring (port 4100) — Fastify WS proctoring service"
  ],
  "databases": [
    "PostgreSQL 16 (port 5432) — primary data store, DB: eduproctordb",
    "Redis 7 (port 6379) — caching + session state"
  ],
  "apps": [
    "web (src/apps/web) — Next.js 14 + Tailwind + React 18",
    "proctoring (src/apps/proctoring) — WebSocket proctoring",
    "api (src/services/api) — NestJS 10 REST API"
  ],
  "shared_packages": [
    "src/shared/types (@eduproctor/types)",
    "src/shared/ui (@eduproctor/ui)",
    "src/shared/utils",
    "src/shared/config"
  ],
  "external_integrations": [
    "Stripe (payments)",
    "AWS S3 (file storage, presigned URLs)",
    "AI Face Matching API (eKYC)"
  ],
  "notable_features": [
    "eKYC with CCCD front/back scan + face photo matching",
    "Proctored exam sessions with violation tracking",
    "Certificate issuance with outbox pattern",
    "PII audit logging (ND 13/2023 compliance)",
    "Course Q&A, section/lecture reordering",
    "Stripe payment with webhook",
    "JWT auth with email verification + password reset",
    "Postponement tickets for exam scheduling"
  ]
}
